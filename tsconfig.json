{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Void-Set",

  "compilerOptions": {
    "lib": ["es2022"],
    "module": "node16",
    "target": "es2022",

    "strict": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node16"
  },
  "exclude": ["node_modules", "**/*.spec.ts"]
}